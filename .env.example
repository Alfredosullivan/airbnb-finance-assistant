# Puerto en el que correrá el servidor
PORT=3000

# ── Conexión a PostgreSQL ──────────────────────────────────────
#
# DATABASE_URL es la única variable que la app lee para conectarse.
# El host cambia según el entorno:
#
#   Modo local (sin Docker, Postgres instalado en Windows):
#     DATABASE_URL=postgresql://postgres:password@localhost:5432/finance_db
#
#   Modo Docker (docker compose up):
#     DATABASE_URL=postgresql://postgres:password@db:5432/finance_db
#     ^ "db" es el nombre del servicio en docker-compose.yml, no "localhost"
#
#   Modo producción (Railway / Render):
#     DATABASE_URL=<pega aquí el string que te da el dashboard de tu proveedor>
#
DATABASE_URL=postgresql://postgres:password@localhost:5432/finance_db

# Variables que usa la imagen oficial de postgres para crear la DB al iniciar el contenedor.
# Deben coincidir con el usuario/contraseña/nombre que está en DATABASE_URL.
# Solo las lee docker-compose.yml — la app Node.js usa únicamente DATABASE_URL.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=finance_db

# Tamaño máximo permitido para archivos PDF (en MB)
MAX_FILE_SIZE_MB=10

# Clave secreta para firmar los tokens JWT de sesión
# IMPORTANTE: Cambia este valor en producción por una cadena larga y aleatoria
JWT_SECRET=cambia_esto_en_produccion

# Orígenes permitidos para CORS (separados por coma; en producción reemplaza con tu dominio real)
ALLOWED_ORIGINS=http://localhost:3000

# API Key de Anthropic para el análisis inteligente con Claude
# Obtén tu clave en https://console.anthropic.com/
# Si no se define, los botones de análisis IA no estarán disponibles
ANTHROPIC_API_KEY=sk-ant-...
