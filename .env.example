# Puerto en el que correrá el servidor
PORT=3000

# Connection string de PostgreSQL
# Local:  postgresql://postgres:password@localhost:5432/finance_db
# Docker: postgresql://postgres:password@db:5432/finance_db
# Railway: usa la variable ${{Postgres.DATABASE_URL}} en el dashboard
DATABASE_URL=postgresql://postgres:password@localhost:5432/finance_db

# Tamaño máximo permitido para archivos subidos (en MB)
MAX_FILE_SIZE_MB=10

# Clave secreta para firmar los tokens JWT
# En producción usa una cadena larga y aleatoria (mínimo 32 caracteres)
JWT_SECRET=cambia_esto_en_produccion

# Orígenes permitidos para CORS (separados por coma)
# En producción reemplaza con tu dominio real
ALLOWED_ORIGINS=http://localhost:3000

# API Key de Anthropic para análisis IA con Claude
# Obtén tu clave en https://console.anthropic.com/
# Si no se define, los botones de análisis IA quedan deshabilitados
ANTHROPIC_API_KEY=